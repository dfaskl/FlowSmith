# Git 忽略文件配置

# IDE
.idea/
.vscode/
*.iml
*.iws
*.ipr

# Maven / Java
backend/target/
backend/.mvn/wrapper/maven-wrapper.jar
*.class
*.jar
*.war
*.nar
*.ear

# 启动脚本（开发者本地使用）
start.cmd
backend/run.cmd

# Spring Boot 构建产物
BOOT-INF/

# JVM crash logs
hs_err_pid*
replay_pid*

# Node
frontend/node_modules/
frontend/dist/
frontend/.vite/

# 环境变量
.env
.env.local
.env.*.local

# 日志
*.log
logs/

# 系统文件
.DS_Store
Thumbs.db

# 数据库
*.db
*.sqlite

# 临时文件
*.tmp
*.temp

# 测试覆盖率
coverage/

# ESLint 缓存
.eslintcache

# 证书/密钥
*.pem
